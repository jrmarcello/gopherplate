func TestDeleteUseCase_Execute_Success(t *testing.T) {
	id := uuid.New()
	repo := &mockRepository{
		DeleteFn: func(_ context.Context, _ uuid.UUID) error {
			return nil
		},
	}

	uc := NewDeleteUseCase(repo)
	input := dto.DeleteInput{ID: id.String()}

	output, execErr := uc.Execute(context.Background(), input)

	require.NoError(t, execErr)
	require.NotNil(t, output)
	assert.Equal(t, id.String(), output.ID)
	assert.NotEmpty(t, output.DeletedAt)
}

func TestDeleteUseCase_Execute_NotFound(t *testing.T) {
	repo := &mockRepository{
		DeleteFn: func(_ context.Context, _ uuid.UUID) error {
			return {{.DomainNameCamel}}domain.Err{{.DomainNamePascal}}NotFound
		},
	}

	uc := NewDeleteUseCase(repo)
	input := dto.DeleteInput{ID: uuid.New().String()}

	output, execErr := uc.Execute(context.Background(), input)

	assert.Error(t, execErr)
	assert.Nil(t, output)

	var appErr *apperror.AppError
	assert.True(t, errors.As(execErr, &appErr))
	assert.Equal(t, apperror.CodeNotFound, appErr.Code)
}

