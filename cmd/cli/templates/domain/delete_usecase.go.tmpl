package {{.DomainNameSnake}}

import (
	"context"
	"fmt"

	"github.com/google/uuid"

	"{{.ModulePath}}/internal/usecases/{{.DomainNameSnake}}/dto"
	"{{.ModulePath}}/internal/usecases/{{.DomainNameSnake}}/interfaces"

	ucshared "{{.ModulePath}}/internal/usecases/shared"
	"go.opentelemetry.io/otel/trace"
)

// DeleteUseCase implements the {{.DomainNameSnake}} deletion use case.
type DeleteUseCase struct {
	Repo interfaces.Repository
}

// NewDeleteUseCase creates a new instance of DeleteUseCase.
func NewDeleteUseCase(repo interfaces.Repository) *DeleteUseCase {
	return &DeleteUseCase{Repo: repo}
}

// Execute deletes a {{.DomainNameSnake}} by ID.
func (uc *DeleteUseCase) Execute(ctx context.Context, input dto.DeleteInput) (*dto.DeleteOutput, error) {
	span := trace.SpanFromContext(ctx)

	id, parseErr := uuid.Parse(input.ID)
	if parseErr != nil {
		ucshared.ClassifyError(span, parseErr, deleteExpectedErrors, "deleting {{.DomainNameSnake}}: invalid ID")
		return nil, {{.DomainNameCamel}}ToAppError(parseErr)
	}

	if deleteErr := uc.Repo.Delete(ctx, id); deleteErr != nil {
		wrappedErr := fmt.Errorf("deleting {{.DomainNameSnake}}: %w", deleteErr)
		ucshared.ClassifyError(span, deleteErr, deleteExpectedErrors, wrappedErr.Error())
		return nil, {{.DomainNameCamel}}ToAppError(deleteErr)
	}

	return &dto.DeleteOutput{ID: input.ID}, nil
}
