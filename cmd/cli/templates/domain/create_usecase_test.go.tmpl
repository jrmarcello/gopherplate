func TestCreateUseCase_Execute_RepositoryError(t *testing.T) {
	repo := &mockRepository{
		CreateFn: func(_ context.Context, _ *{{.DomainNameCamel}}domain.{{.DomainNamePascal}}) error {
			return errors.New("database connection failed")
		},
	}

	uc := NewCreateUseCase(repo)
	input := dto.CreateInput{Name: "Test {{.DomainNamePascal}}"}

	output, execErr := uc.Execute(context.Background(), input)

	assert.Error(t, execErr)
	assert.Nil(t, output)

	var appErr *apperror.AppError
	assert.True(t, errors.As(execErr, &appErr))
	assert.Equal(t, apperror.CodeInternalError, appErr.Code)
}

