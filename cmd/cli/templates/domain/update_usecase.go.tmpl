package {{.DomainNameSnake}}

import (
	"context"
	"fmt"
	"time"

	"github.com/google/uuid"

	"{{.ModulePath}}/internal/usecases/{{.DomainNameSnake}}/dto"
	"{{.ModulePath}}/internal/usecases/{{.DomainNameSnake}}/interfaces"

	ucshared "{{.ModulePath}}/internal/usecases/shared"
	"go.opentelemetry.io/otel/trace"
)

// UpdateUseCase implements the {{.DomainNameSnake}} update use case.
type UpdateUseCase struct {
	Repo interfaces.Repository
}

// NewUpdateUseCase creates a new instance of UpdateUseCase.
func NewUpdateUseCase(repo interfaces.Repository) *UpdateUseCase {
	return &UpdateUseCase{Repo: repo}
}

// Execute updates an existing {{.DomainNameSnake}}.
func (uc *UpdateUseCase) Execute(ctx context.Context, input dto.UpdateInput) (*dto.UpdateOutput, error) {
	span := trace.SpanFromContext(ctx)

	id, parseErr := uuid.Parse(input.ID)
	if parseErr != nil {
		ucshared.ClassifyError(span, parseErr, updateExpectedErrors, "updating {{.DomainNameSnake}}: invalid ID")
		return nil, {{.DomainNameCamel}}ToAppError(parseErr)
	}

	e, findErr := uc.Repo.FindByID(ctx, id)
	if findErr != nil {
		wrappedErr := fmt.Errorf("updating {{.DomainNameSnake}}: %w", findErr)
		ucshared.ClassifyError(span, findErr, updateExpectedErrors, wrappedErr.Error())
		return nil, {{.DomainNameCamel}}ToAppError(findErr)
	}

	if input.Name != nil {
		e.UpdateName(*input.Name)
	}

	if saveErr := uc.Repo.Update(ctx, e); saveErr != nil {
		wrappedErr := fmt.Errorf("updating {{.DomainNameSnake}}: %w", saveErr)
		ucshared.ClassifyError(span, saveErr, updateExpectedErrors, wrappedErr.Error())
		return nil, {{.DomainNameCamel}}ToAppError(saveErr)
	}

	return &dto.UpdateOutput{
		ID:        e.ID.String(),
		Name:      e.Name,
		UpdatedAt: e.UpdatedAt.Format(time.RFC3339),
	}, nil
}
