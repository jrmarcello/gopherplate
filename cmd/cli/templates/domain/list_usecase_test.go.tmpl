func TestListUseCase_Execute_Success(t *testing.T) {
	now := time.Now()
	repo := &mockRepository{
		ListFn: func(_ context.Context, _ {{.DomainNameCamel}}domain.ListFilter) (*{{.DomainNameCamel}}domain.ListResult, error) {
			return &{{.DomainNameCamel}}domain.ListResult{
				Items: []*{{.DomainNameCamel}}domain.{{.DomainNamePascal}}{
					{ID: uuid.New(), Name: "First", CreatedAt: now, UpdatedAt: now},
					{ID: uuid.New(), Name: "Second", CreatedAt: now, UpdatedAt: now},
				},
				Total: 2,
				Page:  1,
				Limit: 20,
			}, nil
		},
	}

	uc := NewListUseCase(repo)
	input := dto.ListInput{Page: 1, Limit: 20}

	output, execErr := uc.Execute(context.Background(), input)

	require.NoError(t, execErr)
	require.NotNil(t, output)
	assert.Len(t, output.Data, 2)
	assert.Equal(t, 2, output.Pagination.Total)
	assert.Equal(t, 1, output.Pagination.Page)
}

