func TestListUseCase_Execute_RepositoryError(t *testing.T) {
	repo := &mockRepository{
		ListFn: func(_ context.Context, _ {{.DomainNameCamel}}domain.ListFilter) (*{{.DomainNameCamel}}domain.ListResult, error) {
			return nil, errors.New("database error")
		},
	}

	uc := NewListUseCase(repo)
	input := dto.ListInput{Page: 1, Limit: 20}

	output, execErr := uc.Execute(context.Background(), input)

	assert.Error(t, execErr)
	assert.Nil(t, output)

	var appErr *apperror.AppError
	assert.True(t, errors.As(execErr, &appErr))
	assert.Equal(t, apperror.CodeInternalError, appErr.Code)
}
