func TestGetUseCase_Execute_Success(t *testing.T) {
	existing := {{.DomainNameCamel}}domain.New{{.DomainNamePascal}}("Test")
	repo := &mockRepository{
		FindByIDFn: func(_ context.Context, _ uuid.UUID) (*{{.DomainNameCamel}}domain.{{.DomainNamePascal}}, error) {
			return existing, nil
		},
	}

	uc := NewGetUseCase(repo)
	input := dto.GetInput{ID: existing.ID.String()}

	output, execErr := uc.Execute(context.Background(), input)

	require.NoError(t, execErr)
	require.NotNil(t, output)
	assert.Equal(t, existing.ID.String(), output.ID)
	assert.Equal(t, "Test", output.Name)
}

func TestGetUseCase_Execute_NotFound(t *testing.T) {
	repo := &mockRepository{
		FindByIDFn: func(_ context.Context, _ uuid.UUID) (*{{.DomainNameCamel}}domain.{{.DomainNamePascal}}, error) {
			return nil, {{.DomainNameCamel}}domain.Err{{.DomainNamePascal}}NotFound
		},
	}

	uc := NewGetUseCase(repo)
	input := dto.GetInput{ID: uuid.New().String()}

	output, execErr := uc.Execute(context.Background(), input)

	assert.Error(t, execErr)
