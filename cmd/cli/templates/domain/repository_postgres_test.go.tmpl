func Test{{.DomainNamePascal}}DB_ToDomain_Success(t *testing.T) {
	now := time.Now().Truncate(time.Microsecond)
	dbModel := {{.DomainNameCamel}}DB{
		ID:        "018e4a2c-6b4d-7000-9410-abcdef123456",
		Name:      "Test Name",
		CreatedAt: now.Add(-24 * time.Hour),
		UpdatedAt: now,
	}

	result, convertErr := dbModel.toDomain()

	assert.NoError(t, convertErr)
	assert.NotNil(t, result)
	assert.Equal(t, "018e4a2c-6b4d-7000-9410-abcdef123456", result.ID.String())
	assert.Equal(t, "Test Name", result.Name)
	assert.Equal(t, now.Add(-24*time.Hour), result.CreatedAt)
	assert.Equal(t, now, result.UpdatedAt)
}

func Test{{.DomainNamePascal}}DB_ToDomain_InvalidID(t *testing.T) {
	dbModel := {{.DomainNameCamel}}DB{
		ID:   "invalid-id",
		Name: "Test",
	}

	result, convertErr := dbModel.toDomain()

	assert.Error(t, convertErr)
	assert.Nil(t, result)
	assert.Contains(t, convertErr.Error(), "parsing ID")
}

func TestFromDomain{{.DomainNamePascal}}(t *testing.T) {
	now := time.Now().Truncate(time.Microsecond)

	entity := &{{.DomainNameCamel}}domain.{{.DomainNamePascal}}{
		ID:        uuid.New(),
		Name:      "Test Name",
		CreatedAt: now.Add(-24 * time.Hour),
		UpdatedAt: now,
	}

	dbModel := fromDomain{{.DomainNamePascal}}(entity)

	assert.Equal(t, entity.ID.String(), dbModel.ID)
	assert.Equal(t, entity.Name, dbModel.Name)
	assert.Equal(t, entity.CreatedAt, dbModel.CreatedAt)
	assert.Equal(t, entity.UpdatedAt, dbModel.UpdatedAt)
}

func TestFromDomain{{.DomainNamePascal}}_RoundTrip(t *testing.T) {
	now := time.Now().Truncate(time.Microsecond)

	original := &{{.DomainNameCamel}}domain.{{.DomainNamePascal}}{
		ID:        uuid.New(),
		Name:      "Round Trip Test",
		CreatedAt: now.Add(-24 * time.Hour),
		UpdatedAt: now,
