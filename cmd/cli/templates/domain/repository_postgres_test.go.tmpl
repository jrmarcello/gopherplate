func Test{{.DomainNamePascal}}Repository_Update(t *testing.T) {
	db, mock, mockErr := sqlmock.New()
	require.NoError(t, mockErr)
	defer func() { _ = db.Close() }()

	sqlxDB := sqlx.NewDb(db, "postgres")
	repo := New{{.DomainNamePascal}}Repository(sqlxDB, sqlxDB)

	t.Run("success", func(t *testing.T) {
		mock.ExpectBegin()
		mock.ExpectExec("UPDATE {{.DomainNamePlural}} SET").
			WithArgs(sqlmock.AnyArg(), sqlmock.AnyArg(), sqlmock.AnyArg()).
			WillReturnResult(sqlmock.NewResult(0, 1))
		mock.ExpectCommit()

		e := buildTest{{.DomainNamePascal}}()
		updateErr := repo.Update(context.Background(), e)

		assert.NoError(t, updateErr)
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("not found - zero rows affected", func(t *testing.T) {
		mock.ExpectBegin()
		mock.ExpectExec("UPDATE {{.DomainNamePlural}} SET").
			WithArgs(sqlmock.AnyArg(), sqlmock.AnyArg(), sqlmock.AnyArg()).
			WillReturnResult(sqlmock.NewResult(0, 0))
		mock.ExpectRollback()

		e := buildTest{{.DomainNamePascal}}()
