// --- Create ------------------------------------------------------------------

func Test{{.DomainNamePascal}}Repository_Create(t *testing.T) {
	db, mock, mockErr := sqlmock.New()
	require.NoError(t, mockErr)
	defer func() { _ = db.Close() }()

	sqlxDB := sqlx.NewDb(db, "postgres")
	repo := New{{.DomainNamePascal}}Repository(sqlxDB, sqlxDB)

	t.Run("success", func(t *testing.T) {
		mock.ExpectExec("INSERT INTO {{.DomainNamePlural}}").
			WithArgs(sqlmock.AnyArg(), sqlmock.AnyArg(), sqlmock.AnyArg(), sqlmock.AnyArg()).
			WillReturnResult(sqlmock.NewResult(0, 1))

		e := buildTest{{.DomainNamePascal}}()
		createErr := repo.Create(context.Background(), e)

		assert.NoError(t, createErr)
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("duplicate key", func(t *testing.T) {
		pqErr := &pq.Error{Code: "23505"}
		mock.ExpectExec("INSERT INTO {{.DomainNamePlural}}").
			WithArgs(sqlmock.AnyArg(), sqlmock.AnyArg(), sqlmock.AnyArg(), sqlmock.AnyArg()).
			WillReturnError(pqErr)

		e := buildTest{{.DomainNamePascal}}()
		createErr := repo.Create(context.Background(), e)

		assert.Error(t, createErr)
		assert.ErrorIs(t, createErr, {{.DomainNameCamel}}domain.Err{{.DomainNamePascal}}DuplicateKey)
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("database error", func(t *testing.T) {
		mock.ExpectExec("INSERT INTO {{.DomainNamePlural}}").
			WithArgs(sqlmock.AnyArg(), sqlmock.AnyArg(), sqlmock.AnyArg(), sqlmock.AnyArg()).
			WillReturnError(sql.ErrConnDone)

		e := buildTest{{.DomainNamePascal}}()
		createErr := repo.Create(context.Background(), e)

		assert.Error(t, createErr)
		assert.ErrorIs(t, createErr, sql.ErrConnDone)
		assert.NoError(t, mock.ExpectationsWereMet())
	})
}

// --- FindByID ----------------------------------------------------------------

func Test{{.DomainNamePascal}}Repository_FindByID(t *testing.T) {
	db, mock, mockErr := sqlmock.New()
	require.NoError(t, mockErr)
	defer func() { _ = db.Close() }()

	sqlxDB := sqlx.NewDb(db, "postgres")
	repo := New{{.DomainNamePascal}}Repository(sqlxDB, sqlxDB)

	now := time.Now().Truncate(time.Microsecond)
	testID := uuid.New()

	t.Run("success", func(t *testing.T) {
		rows := sqlmock.NewRows([]string{"id", "name", "created_at", "updated_at"}).
			AddRow(testID.String(), "Test Name", now, now)

		mock.ExpectQuery("SELECT .+ FROM {{.DomainNamePlural}} WHERE id").
			WithArgs(testID.String()).
			WillReturnRows(rows)

		result, findErr := repo.FindByID(context.Background(), testID)

		assert.NoError(t, findErr)
		require.NotNil(t, result)
		assert.Equal(t, testID, result.ID)
		assert.Equal(t, "Test Name", result.Name)
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("not found", func(t *testing.T) {
		mock.ExpectQuery("SELECT .+ FROM {{.DomainNamePlural}} WHERE id").
			WithArgs(testID.String()).
			WillReturnError(sql.ErrNoRows)

		result, findErr := repo.FindByID(context.Background(), testID)

		assert.Nil(t, result)
		assert.ErrorIs(t, findErr, {{.DomainNameCamel}}domain.Err{{.DomainNamePascal}}NotFound)
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("database error", func(t *testing.T) {
		mock.ExpectQuery("SELECT .+ FROM {{.DomainNamePlural}} WHERE id").
			WithArgs(testID.String()).
			WillReturnError(sql.ErrConnDone)

		result, findErr := repo.FindByID(context.Background(), testID)

		assert.Nil(t, result)
		assert.Error(t, findErr)
		assert.ErrorIs(t, findErr, sql.ErrConnDone)
		assert.NoError(t, mock.ExpectationsWereMet())
	})
}

// --- List --------------------------------------------------------------------

func Test{{.DomainNamePascal}}Repository_List(t *testing.T) {
	db, mock, mockErr := sqlmock.New(sqlmock.QueryMatcherOption(sqlmock.QueryMatcherRegexp))
	require.NoError(t, mockErr)
	defer func() { _ = db.Close() }()

	sqlxDB := sqlx.NewDb(db, "postgres")
	repo := New{{.DomainNamePascal}}Repository(sqlxDB, sqlxDB)

	now := time.Now().Truncate(time.Microsecond)
	testID := uuid.New()

	t.Run("success with results", func(t *testing.T) {
		mock.ExpectBegin()

		countRows := sqlmock.NewRows([]string{"count"}).AddRow(1)
		mock.ExpectQuery("SELECT COUNT\\(\\*\\) FROM {{.DomainNamePlural}}").
			WillReturnRows(countRows)

		dataRows := sqlmock.NewRows([]string{"id", "name", "created_at", "updated_at"}).
			AddRow(testID.String(), "Test Name", now, now)
		mock.ExpectQuery("SELECT .+ FROM {{.DomainNamePlural}}").
			WillReturnRows(dataRows)

		mock.ExpectCommit()

		filter := {{.DomainNameCamel}}domain.ListFilter{Page: 1, Limit: 20}
		result, listErr := repo.List(context.Background(), filter)

		assert.NoError(t, listErr)
		require.NotNil(t, result)
		assert.Equal(t, 1, result.Total)
		assert.Equal(t, 1, result.Page)
		assert.Equal(t, 20, result.Limit)
		require.Len(t, result.Items, 1)
		assert.Equal(t, testID, result.Items[0].ID)
		assert.Equal(t, "Test Name", result.Items[0].Name)
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("empty result", func(t *testing.T) {
		mock.ExpectBegin()

		countRows := sqlmock.NewRows([]string{"count"}).AddRow(0)
		mock.ExpectQuery("SELECT COUNT\\(\\*\\) FROM {{.DomainNamePlural}}").
			WillReturnRows(countRows)

		dataRows := sqlmock.NewRows([]string{"id", "name", "created_at", "updated_at"})
		mock.ExpectQuery("SELECT .+ FROM {{.DomainNamePlural}}").
			WillReturnRows(dataRows)

		mock.ExpectCommit()

		filter := {{.DomainNameCamel}}domain.ListFilter{Page: 1, Limit: 20}
		result, listErr := repo.List(context.Background(), filter)

		assert.NoError(t, listErr)
		require.NotNil(t, result)
		assert.Equal(t, 0, result.Total)
		assert.Empty(t, result.Items)
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("with name filter", func(t *testing.T) {
		mock.ExpectBegin()

		countRows := sqlmock.NewRows([]string{"count"}).AddRow(1)
		mock.ExpectQuery("SELECT COUNT\\(\\*\\) FROM {{.DomainNamePlural}} WHERE name ILIKE").
			WillReturnRows(countRows)

		dataRows := sqlmock.NewRows([]string{"id", "name", "created_at", "updated_at"}).
			AddRow(testID.String(), "Test Name", now, now)
		mock.ExpectQuery("SELECT .+ FROM {{.DomainNamePlural}}.+WHERE name ILIKE").
			WillReturnRows(dataRows)

		mock.ExpectCommit()

		filter := {{.DomainNameCamel}}domain.ListFilter{Page: 1, Limit: 20, Name: "Test"}
		result, listErr := repo.List(context.Background(), filter)

		assert.NoError(t, listErr)
		require.NotNil(t, result)
		assert.Equal(t, 1, result.Total)
		require.Len(t, result.Items, 1)
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("transaction begin error", func(t *testing.T) {
		mock.ExpectBegin().WillReturnError(sql.ErrConnDone)

		filter := {{.DomainNameCamel}}domain.ListFilter{Page: 1, Limit: 20}
		result, listErr := repo.List(context.Background(), filter)

		assert.Nil(t, result)
		assert.Error(t, listErr)
		assert.Contains(t, listErr.Error(), "beginning read transaction")
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("database error on count query", func(t *testing.T) {
		mock.ExpectBegin()

		mock.ExpectQuery("SELECT COUNT\\(\\*\\) FROM {{.DomainNamePlural}}").
			WillReturnError(sql.ErrConnDone)

		mock.ExpectRollback()

		filter := {{.DomainNameCamel}}domain.ListFilter{Page: 1, Limit: 20}
		result, listErr := repo.List(context.Background(), filter)

		assert.Nil(t, result)
		assert.Error(t, listErr)
		assert.ErrorIs(t, listErr, sql.ErrConnDone)
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("database error on data query", func(t *testing.T) {
		mock.ExpectBegin()

		countRows := sqlmock.NewRows([]string{"count"}).AddRow(5)
		mock.ExpectQuery("SELECT COUNT\\(\\*\\) FROM {{.DomainNamePlural}}").
			WillReturnRows(countRows)

		mock.ExpectQuery("SELECT .+ FROM {{.DomainNamePlural}}").
			WillReturnError(sql.ErrConnDone)

		mock.ExpectRollback()

		filter := {{.DomainNameCamel}}domain.ListFilter{Page: 1, Limit: 20}
		result, listErr := repo.List(context.Background(), filter)

		assert.Nil(t, result)
		assert.Error(t, listErr)
		assert.ErrorIs(t, listErr, sql.ErrConnDone)
		assert.NoError(t, mock.ExpectationsWereMet())
	})

	t.Run("commit error", func(t *testing.T) {
		mock.ExpectBegin()

		countRows := sqlmock.NewRows([]string{"count"}).AddRow(1)
		mock.ExpectQuery("SELECT COUNT\\(\\*\\) FROM {{.DomainNamePlural}}").
			WillReturnRows(countRows)

		dataRows := sqlmock.NewRows([]string{"id", "name", "created_at", "updated_at"}).
			AddRow(testID.String(), "Test Name", now, now)
		mock.ExpectQuery("SELECT .+ FROM {{.DomainNamePlural}}").
			WillReturnRows(dataRows)

		mock.ExpectCommit().WillReturnError(sql.ErrConnDone)

		filter := {{.DomainNameCamel}}domain.ListFilter{Page: 1, Limit: 20}
		result, listErr := repo.List(context.Background(), filter)

		assert.Nil(t, result)
		assert.Error(t, listErr)
		assert.Contains(t, listErr.Error(), "committing read transaction")
		assert.NoError(t, mock.ExpectationsWereMet())
	})
}

