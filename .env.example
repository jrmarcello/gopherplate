# Servidor
SERVER_PORT=8080
GIN_MODE=                                  # "", "release", "debug", "test" (default: debug)
HTTP_MAX_BODY_SIZE=1048576                 # Max request body em bytes (default: 1MB)

# Postgres (Writer)
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=entities
DB_SSLMODE=disable

# Postgres Pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=90s

# Postgres Replica (opcional — para DB cluster com read replicas)
# DB_REPLICA_ENABLED=false
# DB_REPLICA_HOST=reader-host
# DB_REPLICA_PORT=5432
# DB_REPLICA_USER=user
# DB_REPLICA_PASSWORD=password
# DB_REPLICA_NAME=entities
# DB_REPLICA_SSLMODE=disable
# DB_REPLICA_MAX_OPEN_CONNS=40
# DB_REPLICA_MAX_IDLE_CONNS=20
# DB_REPLICA_CONN_MAX_LIFETIME=5m
# DB_REPLICA_CONN_MAX_IDLE_TIME=90s

# Redis (Cache)
REDIS_URL=redis://localhost:6379
REDIS_TTL=5m
REDIS_ENABLED=true

# Redis Pool
REDIS_POOL_SIZE=30
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT=500ms
REDIS_READ_TIMEOUT=200ms
REDIS_WRITE_TIMEOUT=200ms

# Swagger (default false in code — set true for local dev)
SWAGGER_ENABLED=true
SWAGGER_HOST=

# Observabilidade (opcional)
OTEL_SERVICE_NAME=entity-service
OTEL_COLLECTOR_URL=
OTEL_INSECURE=true

# Autenticação
# SERVICE_KEYS_ENABLED=false (default — modo dev, tudo permitido)
# Em HML/PRD deve ser true (fail-closed: sem keys = 503)
SERVICE_KEYS_ENABLED=false
# SERVICE_KEYS=myservice:sk_myservice_abc123

# Idempotência (requer REDIS_ENABLED=true)
IDEMPOTENCY_ENABLED=false
IDEMPOTENCY_TTL=24h                        # Duração do armazenamento de respostas
IDEMPOTENCY_LOCK_TTL=30s                   # Duração do lock de processamento
